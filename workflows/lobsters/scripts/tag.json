{
  "pipeline": [
    {
      "fetch": "https://lobste.rs/t/${{ args.tag | urlencode }}.json"
    },
    {
      "map": {
        "rank": "${{ index + 1 }}",
        "title": "${{ item.title }}",
        "score": "${{ item.score }}",
        "author": "${{ item.submitter_user }}",
        "comments": "${{ item.comment_count }}",
        "tags": "${{ item.tags | join(', ') }}",
        "url": "${{ item.comments_url }}"
      }
    },
    {
      "limit": "${{ args.limit }}"
    }
  ]
}
